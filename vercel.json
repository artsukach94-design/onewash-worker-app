{
  "rewrites": [
    { "source": "/:slug/admin", "destination": "/admin/index.html" },
    { "source": "/:slug/admin/", "destination": "/admin/index.html" },
    { "source": "/:slug/admin/:path+", "destination": "/admin/:path*" },
    { "source": "/:slug", "destination": "/index.html" },
    { "source": "/:slug/", "destination": "/index.html" },
    { "source": "/:slug/:path+", "destination": "/:path*" }
  ]
}
